Use the packaged concurrentqueue target for PyTorch's public Semaphore header,
make the exported CMake SDK rediscover it, and link the ROCm backend to
rocm_smi64 for its RSMI calls. This patch applies after the system fmt patch.

diff --git a/c10/CMakeLists.txt b/c10/CMakeLists.txt
index 107afc6..9e488e1 100644
--- a/c10/CMakeLists.txt
+++ b/c10/CMakeLists.txt
@@ -94,7 +94,8 @@ if(NOT BUILD_LIBTORCHLESS)
   target_link_libraries(c10 PUBLIC headeronly)
   target_link_libraries(c10 PRIVATE fmt::fmt)
   target_link_libraries(c10 PRIVATE nlohmann)
-  target_link_libraries(c10 PRIVATE moodycamel)
+  # Semaphore.h is public and includes moodycamel/concurrentqueue.h.
+  target_link_libraries(c10 PUBLIC moodycamel)

   if(C10_USE_NUMA)
     message(STATUS "NUMA paths:")
diff --git a/cmake/Caffe2Config.cmake.in b/cmake/Caffe2Config.cmake.in
index 3465e91..73b83a2 100644
--- a/cmake/Caffe2Config.cmake.in
+++ b/cmake/Caffe2Config.cmake.in
@@ -117,6 +117,10 @@ if(@USE_MKLDNN@)
   include("${CMAKE_CURRENT_LIST_DIR}/public/mkldnn.cmake")
 endif()

+# c10's public Semaphore.h includes moodycamel/concurrentqueue.h and its
+# exported target propagates the corresponding include directory.
+find_package(concurrentqueue REQUIRED)
+
 # import targets
 include ("${CMAKE_CURRENT_LIST_DIR}/Caffe2Targets.cmake")

diff --git a/cmake/Dependencies.cmake b/cmake/Dependencies.cmake
index cabef9c..507e81f 100644
--- a/cmake/Dependencies.cmake
+++ b/cmake/Dependencies.cmake
@@ -1097,7 +1097,7 @@ if(USE_ROCM)
        $<INSTALL_INTERFACE:include> ${Caffe2_HIP_INCLUDE})

     set(Caffe2_PUBLIC_HIP_DEPENDENCY_LIBS
-      hip::host MIOpen hiprtc::hiprtc)
+      hip::host MIOpen hiprtc::hiprtc rocm_smi64)

     # Math libraries
     list(APPEND Caffe2_PUBLIC_HIP_DEPENDENCY_LIBS
@@ -1744,6 +1744,6 @@ target_include_directories(httplib SYSTEM INTERFACE ${PROJECT_SOURCE_DIR}/third_
 add_library(nlohmann INTERFACE IMPORTED)
 include_directories(nlohmann SYSTEM INTERFACE ${PROJECT_SOURCE_DIR}/third_party/nlohmann/include)

-# Include moodycamel
-add_library(moodycamel INTERFACE IMPORTED)
-include_directories(moodycamel SYSTEM INTERFACE ${PROJECT_SOURCE_DIR}/third_party/concurrentqueue)
+# Include the system moodycamel concurrentqueue package.
+find_package(concurrentqueue REQUIRED)
+add_library(moodycamel ALIAS concurrentqueue::concurrentqueue)
