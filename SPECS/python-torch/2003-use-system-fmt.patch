--- a/c10/CMakeLists.txt
+++ b/c10/CMakeLists.txt
@@ -92,7 +92,7 @@ if(NOT BUILD_LIBTORCHLESS)
   endif()

   target_link_libraries(c10 PUBLIC headeronly)
-  target_link_libraries(c10 PRIVATE fmt::fmt-header-only)
