From 63287937d70ba01492a1ec9030b767a708552ef4 Mon Sep 17 00:00:00 2001
From: HNO3Miracle <xiangao.or@isrc.iscas.ac.cn>
Date: Sun, 7 Jun 2026 20:31:32 +0800
Subject: [PATCH] fix non-constant and invalid test format strings

---
 pkg/server/sotw/v3/ads.go   | 2 +-
 pkg/server/v3/delta_test.go | 4 ++--
 2 files changed, 3 insertions(+), 3 deletions(-)

diff --git a/pkg/server/sotw/v3/ads.go b/pkg/server/sotw/v3/ads.go
index 705a5a0..4663f96 100644
--- a/pkg/server/sotw/v3/ads.go
+++ b/pkg/server/sotw/v3/ads.go
@@ -49,7 +49,7 @@ func (s *server) processADS(sw *streamWrapper, reqCh chan *discovery.DiscoveryRe
 		// We only watch the multiplexed channel since we don't use per watch channels.
 		case res := <-respChan:
 			if err := sw.send(res); err != nil {
-				return status.Errorf(codes.Unavailable, err.Error())
+				return status.Errorf(codes.Unavailable, "%s", err.Error())
 			}
 		case req, ok := <-reqCh:
 			// Input stream ended or failed.
diff --git a/pkg/server/v3/delta_test.go b/pkg/server/v3/delta_test.go
index bda3fe8..b1b35df 100644
--- a/pkg/server/v3/delta_test.go
+++ b/pkg/server/v3/delta_test.go
@@ -421,7 +421,7 @@ func TestDeltaCancellations(t *testing.T) {
 		t.Errorf("DeltaAggregatedResources() => got %v, want no error", err)
 	}
 	if config.watches != 0 {
-		t.Errorf("Expect all watches canceled, got %q", config.watches)
+		t.Errorf("Expect all watches canceled, got %d", config.watches)
 	}
 }
 
@@ -443,7 +443,7 @@ func TestDeltaOpaqueRequestsChannelMuxing(t *testing.T) {
 		t.Errorf("DeltaAggregatedResources() => got %v, want no error", err)
 	}
 	if config.watches != 0 {
-		t.Errorf("Expect all watches canceled, got %q", config.watches)
+		t.Errorf("Expect all watches canceled, got %d", config.watches)
 	}
 }
 
