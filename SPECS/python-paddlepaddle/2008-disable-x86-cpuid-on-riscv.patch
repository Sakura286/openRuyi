From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Gui-Yue <xiangwei.riscv@isrc.iscas.ac.cn>
Date: Sat, 20 Jun 2026 00:00:00 +0800
Subject: [PATCH] Disable x86 CPUID on riscv

---
 paddle/phi/backends/cpu/cpu_info.cc | 3 ++-
 paddle/phi/backends/cpu/cpu_info.h  | 3 ++-
 2 files changed, 4 insertions(+), 2 deletions(-)

diff --git a/paddle/phi/backends/cpu/cpu_info.cc b/paddle/phi/backends/cpu/cpu_info.cc
index 079b1730e4..cae99d51d6 100644
--- a/paddle/phi/backends/cpu/cpu_info.cc
+++ b/paddle/phi/backends/cpu/cpu_info.cc
@@ -151,6 +151,7 @@ bool MayIUse(const cpu_isa_t cpu_isa) {
 #if !defined(WITH_NV_JETSON) && !defined(PADDLE_WITH_ARM) &&  \
     !defined(PADDLE_WITH_SW) && !defined(PADDLE_WITH_MIPS) && \
-    !defined(PADDLE_WITH_LOONGARCH)
+    !defined(PADDLE_WITH_LOONGARCH) &&                         \
+    !defined(__riscv)
     std::array<int, 4> reg;
     cpuid(reg.data(), 0);
     int nIds = reg[0];
diff --git a/paddle/phi/backends/cpu/cpu_info.h b/paddle/phi/backends/cpu/cpu_info.h
index 55e0636543..344b68b814 100644
--- a/paddle/phi/backends/cpu/cpu_info.h
+++ b/paddle/phi/backends/cpu/cpu_info.h
@@ -42,7 +42,8 @@
 #else
 #if !defined(WITH_NV_JETSON) && !defined(PADDLE_WITH_ARM) &&  \
     !defined(PADDLE_WITH_SW) && !defined(PADDLE_WITH_MIPS) && \
-    !defined(PADDLE_WITH_LOONGARCH)
+    !defined(PADDLE_WITH_LOONGARCH) &&                         \
+    !defined(__riscv)
 #include <cpuid.h>
 inline void cpuid(int reg[4], int x) {
   __cpuid_count(x, 0, reg[0], reg[1], reg[2], reg[3]);
-- 
2.51.0
