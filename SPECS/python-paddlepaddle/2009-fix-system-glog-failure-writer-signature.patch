# Patch purpose:
# - Match Paddle's failure writer callback with system glog's current
#   InstallFailureWriter signature.
# Why this patch exists:
# - openRuyi uses a system glog whose InstallFailureWriter callback takes
#   size_t for the message length. Paddle 3.3.1 still declares the local
#   callback with int, which is rejected by GCC as an invalid function pointer
#   conversion.

diff -uprN a/paddle/fluid/platform/init.cc b/paddle/fluid/platform/init.cc
--- a/paddle/fluid/platform/init.cc	2026-03-19 14:53:19.000000000 +0800
+++ b/paddle/fluid/platform/init.cc	2026-06-20 01:46:15.396339697 +0800
@@ -291,7 +291,7 @@ const char *ParseSignalErrorString(const
 }
 
 // Handle SIGSEGV, SIGILL, SIGFPE, SIGABRT, SIGBUS, and SIGTERM.
-void SignalHandle(const char *data, int size) {
+void SignalHandle(const char *data, std::size_t size) {
   try {
     // NOTE1: The glog FailureSignalHandler dumped messages
     //   are deal with line by line
diff -uprN a/paddle/fluid/platform/init.h b/paddle/fluid/platform/init.h
--- a/paddle/fluid/platform/init.h	2026-03-19 14:53:19.000000000 +0800
+++ b/paddle/fluid/platform/init.h	2026-06-20 01:46:15.392339567 +0800
@@ -12,6 +12,7 @@ WITHOUT WARRANTIES OR CONDITIONS OF ANY
 See the License for the specific language governing permissions and
 limitations under the License. */
 #pragma once
+#include <cstddef>
 #include <memory>
 #include <mutex>  // NOLINT
 #include <string>
@@ -53,7 +54,7 @@ class SignalMessageDumper {
   std::shared_ptr<std::ostringstream> dumper_;
 };
 
-void SignalHandle(const char* data, int size);
+void SignalHandle(const char* data, std::size_t size);
 #endif
 
 PADDLE_API void DisableSignalHandler();
