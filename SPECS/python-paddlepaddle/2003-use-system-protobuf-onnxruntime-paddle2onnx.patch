+    PATHS ${PROTOBUF_ROOT}/lib ${PROTOBUF_ROOT}/lib64
     NO_DEFAULT_PATH)
   find_library(
     PROTOBUF_PROTOC_LIBRARY protoc libprotoc.lib
-    PATHS ${PROTOBUF_ROOT}/lib
+    PATHS ${PROTOBUF_ROOT}/lib ${PROTOBUF_ROOT}/lib64
     NO_DEFAULT_PATH)
   find_program(
     PROTOBUF_PROTOC_EXECUTABLE protoc
