# Patch purpose:
# - Use system protobuf, ONNX Runtime, and Paddle2ONNX when requested.
# Why this patch exists:
# - Upstream Paddle downloads or builds pinned bundled dependencies by default.
# - openRuyi packages must use the distribution-wide protobuf and avoid bundled x86_64 ONNX Runtime/Paddle2ONNX binaries.

diff --git a/CMakeLists.txt b/CMakeLists.txt
index 6ea73365e8..9f80fd3303 100755
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -63,6 +63,8 @@ option(WITH_WIN_DUMP_DBG "Compile with windows core dump debug mode" OFF)
 option(WITH_ROCM "Compile PaddlePaddle with ROCM platform" OFF)
 option(WITH_IPU "Compile PaddlePaddle with Graphcore IPU" OFF)
 option(WITH_ONNXRUNTIME "Compile PaddlePaddle with ONNXRUNTIME" OFF)
+option(WITH_SYSTEM_ONNXRUNTIME "Use system ONNX Runtime instead of bundled binary" OFF)
+option(WITH_SYSTEM_PADDLE2ONNX "Use system Paddle2ONNX instead of bundled binary" OFF)
 option(WITH_CUSPARSELT "Compile PaddlePaddle with CUSPARSELT" OFF)
 option(WITH_SETUP_INSTALL "Compile PaddlePaddle with setup.py" OFF)
 option(WITH_SHARED_PHI "Compile PaddlePaddle with SHARED LIB of PHI" ON)
diff --git a/cmake/external/onnxruntime.cmake b/cmake/external/onnxruntime.cmake
index 76d534e0c0..6e62bd8be7 100644
--- a/cmake/external/onnxruntime.cmake
+++ b/cmake/external/onnxruntime.cmake
@@ -25,6 +25,40 @@ include(ExternalProject)
 
 add_definitions(-DPADDLE_WITH_ONNXRUNTIME)
 
+if(WITH_SYSTEM_ONNXRUNTIME)
+  find_path(
+    ONNXRUNTIME_INC_DIR
+    NAMES onnxruntime_c_api.h
+    PATH_SUFFIXES include include/onnxruntime include/onnxruntime/core/session)
+  find_library(ONNXRUNTIME_SHARED_LIB NAMES onnxruntime)
+  if(NOT ONNXRUNTIME_INC_DIR OR NOT ONNXRUNTIME_SHARED_LIB)
+    message(FATAL_ERROR "System ONNX Runtime requested but not found")
+  endif()
+
+  get_filename_component(ONNXRUNTIME_LIB_DIR ${ONNXRUNTIME_SHARED_LIB}
+                         DIRECTORY)
+  get_filename_component(ONNXRUNTIME_LIB_NAME ${ONNXRUNTIME_SHARED_LIB} NAME)
+  set(ONNXRUNTIME_LIB
+      ${ONNXRUNTIME_SHARED_LIB}
+      CACHE FILEPATH "ONNXRUNTIME library." FORCE)
+  set(ONNXRUNTIME_SHARED_LIB
+      ${ONNXRUNTIME_SHARED_LIB}
+      CACHE FILEPATH "ONNXRUNTIME shared library." FORCE)
+  set(ONNXRUNTIME_LIB_DIR
+      ${ONNXRUNTIME_LIB_DIR}
+      CACHE PATH "ONNXRUNTIME library directory." FORCE)
+  set(ONNXRUNTIME_LIB_NAME
+      ${ONNXRUNTIME_LIB_NAME}
+      CACHE STRING "ONNXRUNTIME library name." FORCE)
+  include_directories(${ONNXRUNTIME_INC_DIR})
+  add_library(onnxruntime SHARED IMPORTED GLOBAL)
+  set_property(TARGET onnxruntime PROPERTY IMPORTED_LOCATION
+                                           ${ONNXRUNTIME_LIB})
+  set_property(TARGET onnxruntime PROPERTY INTERFACE_INCLUDE_DIRECTORIES
+                                           ${ONNXRUNTIME_INC_DIR})
+  return()
+endif()
+
 set(ONNXRUNTIME_PROJECT "extern_onnxruntime")
 set(ONNXRUNTIME_VERSION "1.11.1")
 set(ONNXRUNTIME_PREFIX_DIR ${THIRD_PARTY_PATH}/onnxruntime)
diff --git a/cmake/external/paddle2onnx.cmake b/cmake/external/paddle2onnx.cmake
index decb6c9168..43103f658d 100644
--- a/cmake/external/paddle2onnx.cmake
+++ b/cmake/external/paddle2onnx.cmake
@@ -23,6 +23,39 @@ endif()
 
 include(ExternalProject)
 
+if(WITH_SYSTEM_PADDLE2ONNX)
+  find_path(
+    PADDLE2ONNX_INC_DIR
+    NAMES paddle2onnx/converter.h
+    PATH_SUFFIXES include)
+  find_library(PADDLE2ONNX_LIB NAMES paddle2onnx)
+  if(NOT PADDLE2ONNX_INC_DIR OR NOT PADDLE2ONNX_LIB)
+    message(FATAL_ERROR "System Paddle2ONNX requested but not found")
+  endif()
+
+  get_filename_component(PADDLE2ONNX_LIB_DIR ${PADDLE2ONNX_LIB} DIRECTORY)
+  get_filename_component(PADDLE2ONNX_LIB_NAME ${PADDLE2ONNX_LIB} NAME)
+  set(PADDLE2ONNX_LIB
+      ${PADDLE2ONNX_LIB}
+      CACHE FILEPATH "PADDLE2ONNX library." FORCE)
+  set(PADDLE2ONNX_COMPILE_LIB
+      ${PADDLE2ONNX_LIB}
+      CACHE FILEPATH "PADDLE2ONNX compile library." FORCE)
+  set(PADDLE2ONNX_LIB_DIR
+      ${PADDLE2ONNX_LIB_DIR}
+      CACHE PATH "PADDLE2ONNX library directory." FORCE)
+  set(PADDLE2ONNX_LIB_NAME
+      ${PADDLE2ONNX_LIB_NAME}
+      CACHE STRING "PADDLE2ONNX library name." FORCE)
+  include_directories(${PADDLE2ONNX_INC_DIR})
+  add_library(paddle2onnx SHARED IMPORTED GLOBAL)
+  set_property(TARGET paddle2onnx PROPERTY IMPORTED_LOCATION
+                                           ${PADDLE2ONNX_COMPILE_LIB})
+  set_property(TARGET paddle2onnx PROPERTY INTERFACE_INCLUDE_DIRECTORIES
+                                           ${PADDLE2ONNX_INC_DIR})
+  return()
+endif()
+
 set(PADDLE2ONNX_PROJECT "extern_paddle2onnx")
 set(PADDLE2ONNX_VERSION "1.0.0rc2")
 set(PADDLE2ONNX_PREFIX_DIR ${THIRD_PARTY_PATH}/paddle2onnx)
