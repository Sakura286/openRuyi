# Server-specific additions to openRuyi defaults
# We use an 80- prefix so this runs BEFORE the disable * rule in 90-openruyi-default.preset

# Enable common server daemons
enable httpd.service
enable nginx.service
enable mariadb.service
enable postgresql.service
enable redis.service
enable keepalived.service

# Virtualization and Containerization
enable libvirtd.service
enable virtqemud.socket
enable virtnetworkd.socket
enable virtnodedevd.socket
enable virtnwfilterd.socket
enable virtsecretd.socket
enable virtstoraged.socket
enable docker.socket
enable containerd.service
enable podman.socket
