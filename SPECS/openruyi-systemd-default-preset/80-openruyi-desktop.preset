# Desktop-specific additions to openRuyi defaults
# We use an 80- prefix so this runs BEFORE the disable * rule in 90-openruyi-default.preset

# Enable ModemManager for mobile broadband
enable ModemManager.service

# Desktop is similar to workstation, slightly more consumer focused
enable graphical.target
enable gdm.service
enable sddm.service
enable lightdm.service

enable cups.service
enable bluetooth.service
enable avahi-daemon.*
enable upower.service
enable polkit.service
enable fstrim.timer
