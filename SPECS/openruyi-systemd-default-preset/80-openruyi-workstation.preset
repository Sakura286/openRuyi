# Workstation-specific additions to openRuyi defaults
# We use an 80- prefix so this runs BEFORE the disable * rule in 90-openruyi-default.preset

# Enable ModemManager for mobile broadband
enable ModemManager.service

# Enable graphical target and login managers
enable graphical.target
enable gdm.service
enable sddm.service
enable lightdm.service

# Enable printing and desktop services
enable cups.service
enable bluetooth.service
enable thermald.service
enable power-profiles-daemon.service

# Virtualization and Containerization
enable libvirtd.service
enable virtqemud.socket
enable virtnetworkd.socket
enable virtnodedevd.socket
enable virtnwfilterd.socket
enable virtsecretd.socket
enable virtstoraged.socket
enable docker.socket
enable containerd.service
enable podman.socket
