From a528c421d34d26a8e03b2465ca097bd9ed669000 Mon Sep 17 00:00:00 2001
From: Icenowy Zheng <uwu@icenowy.me>
Date: Thu, 25 Dec 2025 01:56:07 +0800
Subject: [PATCH] isaspec: deocde: try to preserve NaN sign when printing it on
 RISC-V

On RISC-V, just use printf-alike functions to print a float-typed -nan
will get a "nan" result without negative sign because the negative sign
will be omitted when promoting the float value to double (the RISC-V
specification requires NaN canonicalization which erases the sign bit).

As the sign bit is meaningful when disaseembling, add some code to
manually promote the float to double with sign preservation.

This mimics what libstdc++ does, see [1].

[1] https://gcc.gnu.org/cgit/gcc/commit/?id=ee9f00606f184be37d6f9df74cc7e222157c7fee

Signed-off-by: Icenowy Zheng <uwu@icenowy.me>
---
 src/compiler/isaspec/isaspec_decode_impl.c | 15 ++++++++++++---
 1 file changed, 12 insertions(+), 3 deletions(-)

diff --git a/src/compiler/isaspec/isaspec_decode_impl.c b/src/compiler/isaspec/isaspec_decode_impl.c
index c3f9a5ce108..8518971f673 100644
--- a/src/compiler/isaspec/isaspec_decode_impl.c
+++ b/src/compiler/isaspec/isaspec_decode_impl.c
@@ -638,14 +638,23 @@ display_field(struct decode_scope *scope, const char *field_name)
 			isa_print(print, "+%"PRIu64, val);
 		}
 		break;
-	case TYPE_FLOAT:
+	case TYPE_FLOAT: {
+		double dval;
+		float fval;
 		if (width == 16) {
-			isa_print(print, "%f", _mesa_half_to_float(val));
+			fval = _mesa_half_to_float(val);
 		} else {
 			assert(width == 32);
-			isa_print(print, "%f", uif(val));
+			fval = uif(val);
 		}
+#if !defined(__riscv)
+		dval = fval;
+#else
+		dval = copysign((double) fval, signbit(fval) ? -1.0 : 1.0);
+#endif
+		isa_print(print, "%lf", dval);
 		break;
+	}
 	case TYPE_BOOL:
 		if (field->display) {
 			if (val) {
-- 
