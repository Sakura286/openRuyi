From 2f324ae66e475cafd381844a45693e3c2869c7dd Mon Sep 17 00:00:00 2001
From: CHEN Xuan <chenxuan@iscas.ac.cn>
Date: Sat, 18 Jul 2026 20:00:00 +0800
Subject: [PATCH] tensilelite: add heartbeat during parallel map to avoid OBS
 build timeout

When generating assembly kernels on slow platforms (e.g. riscv64 emulation),
Tensile's ParallelMap2 can run for a long time without emitting any output, so
OBS kills the build once its logidlelimit (no-output limit) is exceeded.

Add a background HeartbeatMonitor that prints progress every 60 seconds during
the parallel execution, keeping the build alive past the idle limit. The monitor
runs entirely in the parent process and does NOT wrap the per-task callable, so
the task and its arguments stay picklable for joblib's loky workers (wrapping it
in a closure that captured the monitor raised "cannot pickle '_thread.lock'
object" / PicklingError and broke kernel generation).
---
 tensilelite/Tensile/Common/Parallel.py | 67 +++++++++++++++++++++++---
 1 file changed, 59 insertions(+), 8 deletions(-)

diff --git a/tensilelite/Tensile/Common/Parallel.py b/tensilelite/Tensile/Common/Parallel.py
index 1a2bf9e..23ca705 100644
--- a/tensilelite/Tensile/Common/Parallel.py
+++ b/tensilelite/Tensile/Common/Parallel.py
@@ -23,6 +23,7 @@
 ################################################################################
 
 import concurrent.futures
+import threading
 import itertools
 import os
 import sys
@@ -197,6 +198,41 @@ def ParallelMapReturnAsGenerator(function, objects, message="", enable=True, mul
             yield result.result()
 
 
+class HeartbeatMonitor:
+    """Periodically prints progress to prevent OBS logidlelimit from killing the build."""
+
+    def __init__(self, message, interval=60):
+        self.message = message
+        self.interval = interval
+        self.total = 0
+        self.start_time = None
+        self._stop_event = threading.Event()
+        self._thread = None
+
+    def start(self, total):
+        self.total = total
+        self.start_time = time.time()
+        self._stop_event.clear()
+        self._thread = threading.Thread(target=self._run, daemon=True)
+        self._thread.start()
+
+    def stop(self):
+        self._stop_event.set()
+        if self._thread:
+            self._thread.join(timeout=5)
+
+    def _run(self):
+        while not self._stop_event.wait(self.interval):
+            elapsed = time.time() - self.start_time
+            if self.total > 0:
+                print("{0}Heartbeat: still running {1} tasks, elapsed: {2:.0f}s".format(
+                    self.message, self.total, elapsed))
+            else:
+                print("{0}Heartbeat: still running, elapsed: {1:.0f}s".format(
+                    self.message, elapsed))
+            sys.stdout.flush()
+
+
 def ParallelMap2(
     function, objects, message="", enable=True, multiArg=True, return_as="list", procs=None
 ):
@@ -236,14 +272,29 @@ def ParallelMap2(
     pcall = pcallWithGlobalParamsMultiArg if multiArg else pcallWithGlobalParamsSingleArg
     pargs = zip(objects, itertools.repeat(globalParameters))
 
-    if joblibParallelSupportsGenerator():
-        rv = Parallel(n_jobs=threadCount, timeout=99999, return_as=return_as)(
-            delayed(pcall)(function, a, params) for a, params in pargs
-        )
-    else:
-        rv = Parallel(n_jobs=threadCount, timeout=99999)(
-            delayed(pcall)(function, a, params) for a, params in pargs
-        )
+    # Keep the build alive: emit periodic output during the otherwise-silent
+    # parallel kernel generation so OBS's logidlelimit does not time out. The
+    # heartbeat runs entirely in this (parent) process; the parallel task and
+    # its arguments are left untouched so they stay picklable for the loky
+    # workers.
+    heartbeat = HeartbeatMonitor(message)
+    try:
+        total = len(objects)
+    except TypeError:
+        total = 0
+    heartbeat.start(total)
+
+    try:
+        if joblibParallelSupportsGenerator():
+            rv = Parallel(n_jobs=threadCount, timeout=99999, return_as=return_as)(
+                delayed(pcall)(function, a, params) for a, params in pargs
+            )
+        else:
+            rv = Parallel(n_jobs=threadCount, timeout=99999)(
+                delayed(pcall)(function, a, params) for a, params in pargs
+            )
+    finally:
+        heartbeat.stop()
 
     totalTime = time.time() - currentTime
     print("{0}Done. ({1:.1f} secs elapsed)".format(message, totalTime))
-- 
2.53.0

